{
  "ODVGateway": {
    "openDocViewerDistPath": "../../../OpenDocViewer/dist",
    "allowOpenDocViewerFallbackWithoutSession": true,
    "trustClientFilePath": true,
    "trustedSourceRoots": [
      "{ContentRoot}/../demo"
    ],
    "exposeOpenDocViewerDistPathInHealth": true,
    "webClientHandoff": {
      "allowMissingInitiatorHeaders": true
    }
  }
}
