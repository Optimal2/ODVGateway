<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <httpProtocol>
        <customHeaders>
          <add name="X-Frame-Options" value="SAMEORIGIN" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="Referrer-Policy" value="no-referrer" />
          <!--
            Content-Security-Policy and Strict-Transport-Security are intentionally
            deployment-specific. The gateway injects a small inline bootstrap script
            into the configured OpenDocViewer dist, and standalone deployments may be
            served behind different HTTPS terminators. Add a site-specific CSP/HSTS
            policy in the hosting environment once the final frame/HTTPS topology is
            known.
          -->
        </customHeaders>
      </httpProtocol>
      <!--
        Keep ASP.NET Core stdout logging disabled in the checked-in template.
        Enable it temporarily in a deployment-specific web.config only while
        troubleshooting startup failures; otherwise stdout logs can grow quickly
        and may capture sensitive operational details.
      -->
      <aspNetCore processPath="dotnet" arguments=".\ODVGateway.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxUrl="65536" maxQueryString="65536" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
